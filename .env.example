# Environment Variable Configuration Template
# Copy this file to '.env' and modify the values for your local environment.
# DO NOT commit the actual '.env' file containing real secrets to version control.

# FastAPI Application Settings
PROJECT_NAME="OncoRisk AI API"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Security Configurations
# Generate a secure secret key using: openssl rand -hex 32
SECRET_KEY="local-development-secret-key-replace-in-production-12345"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAIL="admin@oncorisk.ai"
ADMIN_PASSWORD="AdminSecurePassword2026!"

# CORS Configuration
# Comma-separated list of origins allowed to request the API
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","https://oncorisk-ai.vercel.app"]

# Relational Database Connection String
# For docker-compose default setup:
DATABASE_URL="postgresql://postgres:postgres_secure_pass_2026@localhost:5432/oncorisk_db"
